<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="1-init-base" author="Kovalevych_Admin">
        <createTable tableName="countries">
            <column name="id" type="integer" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="continent" type="varchar(50)"/>
        </createTable>

        <createTable tableName="manufacturers">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="country" type="varchar(50)"/>
        </createTable>

        <createTable tableName="cars">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="model" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="price" type="numeric"/>
            <column name="manufacturer_id" type="bigint">
                <constraints foreignKeyName="fk_cars_manufacturer" referencedTableName="manufacturers" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>